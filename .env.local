# ============================================================
# .env.local — Variables de entorno
# ============================================================
# Completa los valores.

# ──────────────────────────────────────────────
# REDIS
# ──────────────────────────────────────────────
# Local:
REDIS_URL=redis://localhost:6379

# Upstash (producción serverless):
# REDIS_URL=rediss://:password@your-upstash-instance.upstash.io:6379

# ──────────────────────────────────────────────
# UPSTASH REDIS
# ──────────────────────────────────────────────
# Obtené las credenciales desde:
#   https://console.upstash.com → tu base de datos → REST API
#
# En Vercel: conectá la integración de Upstash desde el marketplace
# y las variables se inyectan automáticamente.
UPSTASH_REDIS_REST_URL=??
UPSTASH_REDIS_REST_TOKEN=??

# ──────────────────────────────────────────────
# GREEN API (WhatsApp Business)
# ──────────────────────────────────────────────
# Obtené tu instancia en: https://green-api.com
GREEN_API_INSTANCE_ID=??
GREEN_API_TOKEN=??

# ──────────────────────────────────────────────
# WORKER
# ──────────────────────────────────────────────
# Intervalo mínimo entre envíos (ms) — evita rate limiting
WORKER_SEND_INTERVAL_MS=1500

# Secret para proteger el endpoint /api/worker (recomendado en producción)
# WORKER_SECRET=??